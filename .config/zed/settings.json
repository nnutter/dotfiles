// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "mode": "subtle",
    "ollama": {
      "api_url": "http://127.0.0.1:1234"
    },
    "open_ai_compatible_api": {
      "model": "google/gemma-4-e4b",
      "api_url": "http://127.0.0.1:1234/v1"
    }
  },
  "agent": {
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "model": "gpt-5.3-codex",
      "provider": "openai-subscribed",
    },
    "default_profile": "write",
    "dock": "left",
    "favorite_models": [
      {
        "provider": "openai-subscribed",
        "model": "gpt-5.5",
        "enable_thinking": true,
        "effort": "medium"
      },
      {
        "provider": "openai-subscribed",
        "model": "gpt-5.3-codex",
        "enable_thinking": true,
        "effort": "medium"
      },
      {
        "provider": "openai-subscribed",
        "model": "gpt-5.4",
        "enable_thinking": true,
        "effort": "medium"
      },
      {
        "provider": "x_ai",
        "model": "grok-4.3",
        "enable_thinking": false
      },
      {
        "provider": "opencode",
        "model": "zen/kimi-k2.6",
        "enable_thinking": false
      },
      {
        "provider": "opencode",
        "model": "zen/qwen3.6-plus",
        "enable_thinking": false
      },
      {
        "provider": "opencode",
        "model": "zen/glm-5.1",
        "enable_thinking": false
      }
    ],
    "model_parameters": [],
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    }
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 15,
  "cli_default_open_behavior": "existing_window",
  "collaboration_panel": {
    "dock": "right"
  },
  "colorize_brackets": true,
  "git_panel": {
    "dock": "right"
  },
  "inlay_hints": {
    "edit_debounce_ms": 700,
    "enabled": true,
    "scroll_debounce_ms": 50,
    "show_background": false,
    "show_other_hints": true,
    "show_parameter_hints": true,
    "show_type_hints": true,
    "show_value_hints": true,
    "toggle_on_modifiers_press": {
      "alt": false,
      "control": false,
      "function": false,
      "platform": false,
      "shift": false
    }
  },
  "language_models": {
    "lmstudio": {
      "api_url": "http://127.0.0.1:1234",
    },
  },
  "languages": {
    "Go": {
      "inlay_hints": {
        "enabled": false,
        "show_type_hints": false
      }
    },
    "Python": {
      "hard_tabs": true,
      "language_servers": [
        "ty",
        "!basedpyright",
        "!pylsp",
        "!pyright",
        "..."
      ]
    }
  },
  "lsp": {
    "gopls": {
      "settings": {
        "staticcheck": true
      }
    }
  },
  "outline_panel": {
    "dock": "right"
  },
  "project_panel": {
    "dock": "right",
    "hide_gitignore": true,
    "starts_open": false
  },
  "show_edit_predictions": true,
  "terminal": {
    "option_as_meta": true
  },
  "theme": {
    "dark": "Everforest Dark Medium (regular)",
    "light": "One Light",
    "mode": "system"
  },
  "ui_font_size": 16,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "never"
  },
  "vim_mode": true
}
