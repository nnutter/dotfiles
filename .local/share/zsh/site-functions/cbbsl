cbbsl() {
    if [[ -z "$1" ]]; then
        echo "Usage: cbbsl <repository>"
        return 1
    fi

    local repos_dir="$HOME"'/src/github.com/cbbsl'
    local target_dir="$repos_dir/$1"

    if [[ -d "$target_dir" ]]; then
        cd "$target_dir"
    else
        echo "Directory $target_dir does not exist"
        return 1
    fi
}
