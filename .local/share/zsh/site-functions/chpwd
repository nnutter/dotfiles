env_on_chdir () {
  if git rev-parse --is-inside-work-tree 1>/dev/null 2<&1
  then
    local nickname
    nickname=$(git config zmx.nickname 2>/dev/null)
    if test -z "$nickname"
    then
      nickname=$(basename $(git rev-parse --show-toplevel))
    fi
    ZMX_SESSION_PREFIX="${nickname}."

    local current_branch
    current_branch=$(git branch --show-current)
    if test -n "$current_branch"
    then
      ZMX_SESSION_PREFIX="${ZMX_SESSION_PREFIX}.${current_branch}."
    fi

    export ZMX_SESSION_PREFIX
  fi
}

add-zsh-hook chpwd env_on_chdir   
