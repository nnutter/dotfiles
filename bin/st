#!/usr/bin/env python3

import os
import shutil
import subprocess
import sys
from typing import List, Optional


USAGE = "Usage: st [query]"


def run(cmd: List[str], input_text: Optional[str] = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        cmd,
        input=input_text,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )


def require_command(name: str) -> bool:
    if shutil.which(name) is not None:
        return True
    print(f"Missing required command: {name}", file=sys.stderr)
    return False


def list_sessions() -> List[str]:
    result = run(["tmux", "list-sessions", "-F", "#S"])
    if result.returncode != 0:
        return []
    sessions = [line.strip() for line in result.stdout.splitlines() if line.strip()]
    seen = set()
    deduped = []
    for session in sessions:
        if session in seen:
            continue
        seen.add(session)
        deduped.append(session)
    return deduped


def tmux_new_attach(session_name: str) -> int:
    if not session_name:
        print("Session name cannot be empty", file=sys.stderr)
        return 1

    if tmux_session_exists(session_name):
        return tmux_attach(session_name)

    result = subprocess.run(["tmux", "new-session", "-d", "-s", session_name], check=False)
    if result.returncode != 0:
        return result.returncode

    return tmux_attach(session_name)


def tmux_new_attach_git(session_name: str) -> int:
    if not session_name:
        print("Session name cannot be empty", file=sys.stderr)
        return 1

    if tmux_session_exists(session_name):
        return tmux_attach(session_name)

    result = subprocess.run(["tmux", "new-session", "-d", "-s", session_name, "-n", "opencode", "opencode"], check=False)
    if result.returncode != 0:
        return result.returncode

    result = subprocess.run(["tmux", "new-window", "-t", session_name, "-n", "neovim", "nvim", "."], check=False)
    if result.returncode != 0:
        return result.returncode

    result = subprocess.run(["tmux", "new-window", "-t", session_name, "-n", "zsh"], check=False)
    if result.returncode != 0:
        return result.returncode

    result = subprocess.run(["tmux", "select-window", "-t", f"{session_name}:zsh"], check=False)
    if result.returncode != 0:
        return result.returncode

    return tmux_attach(session_name)


def tmux_attach(session_name: str) -> int:
    result = subprocess.run(["tmux", "attach-session", "-t", session_name], check=False)
    return result.returncode


def tmux_session_exists(session_name: str) -> bool:
    result = run(["tmux", "has-session", "-t", session_name])
    return result.returncode == 0


def fzf_select(sessions: List[str], query: Optional[str] = None) -> Optional[str]:
    cmd = ["fzf"]
    if query is not None:
        cmd.extend(["--query", query])
    source = "\n".join(sessions) + "\n"
    result = run(cmd, input_text=source)
    if result.returncode != 0:
        return None
    selected = result.stdout.strip()
    if not selected:
        return None
    return selected


def inside_git_worktree() -> bool:
    result = run(["git", "rev-parse", "--is-inside-work-tree"])
    return result.returncode == 0 and result.stdout.strip() == "true"


def derive_git_session_name() -> Optional[str]:
    top_level = run(["git", "rev-parse", "--show-toplevel"])
    common_dir = run(["git", "rev-parse", "--path-format=absolute", "--git-common-dir"])
    if common_dir.returncode != 0:
        common_dir = run(["git", "rev-parse", "--git-common-dir"])

    if top_level.returncode != 0 or common_dir.returncode != 0:
        return None

    top_path = os.path.abspath(top_level.stdout.strip())
    common_git_dir = os.path.abspath(common_dir.stdout.strip())
    repo_root = os.path.dirname(common_git_dir)

    repo_base = os.path.basename(repo_root)
    worktree_base = os.path.basename(top_path)

    if top_path == repo_root:
        return repo_base
    return f"{repo_base}-{worktree_base}"


def picker_flow(query: Optional[str]) -> int:
    if not require_command("fzf"):
        return 1

    sessions = list_sessions()

    if query is None:
        if not sessions:
            print("No existing sessions", file=sys.stderr)
            return 1
        selected = fzf_select(sessions)
        if selected is None:
            return 1
        return tmux_attach(selected)

    selected = fzf_select(sessions, query=query)
    if selected is not None:
        return tmux_attach(selected)
    return tmux_new_attach(query)


def main(argv: List[str]) -> int:
    if len(argv) > 1:
        print(USAGE, file=sys.stderr)
        return 2

    if not require_command("tmux"):
        return 1

    if len(argv) == 1:
        return picker_flow(argv[0])

    if inside_git_worktree():
        session_name = derive_git_session_name()
        if session_name is None:
            return 1
        return tmux_new_attach_git(session_name)

    return picker_flow(None)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
